{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/casa5", "destination": "https://casa5-nieuw.vercel.app/" },
    { "source": "/casa5/:path*", "destination": "https://casa5-nieuw.vercel.app/:path*" },
    { "source": "/pieterpostkaart", "destination": "https://pieterpostkaartmap.pages.dev/" },
    { "source": "/pieterpostkaart/:path*", "destination": "https://pieterpostkaartmap.pages.dev/:path*" },
    { "source": "/rubens", "destination": "https://rubens-website.vercel.app/" },
    { "source": "/rubens/:path*", "destination": "https://rubens-website.vercel.app/:path*" },
    { "source": "/_next/:path*", "destination": "https://rubens-website.vercel.app/_next/:path*" },
    { "source": "/images/:path*", "destination": "https://rubens-website.vercel.app/images/:path*" }
  ]
}
